# ============================================================
# DATABASE — Supabase PostgreSQL
# ============================================================
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ============================================================
# JWT
# ============================================================
JWT_SECRET="change-this-to-a-long-random-secret-32-chars-min"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-this-to-another-long-random-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# ============================================================
# SUPABASE STORAGE
# ============================================================
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
SUPABASE_STORAGE_BUCKET_FOTOS="vistorias-fotos"
SUPABASE_STORAGE_BUCKET_ANEXOS="vistorias-anexos"
SUPABASE_STORAGE_BUCKET_ASSINATURAS="vistorias-assinaturas"

# ============================================================
# EMAIL — Resend
# ============================================================
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@seudominio.com.br"

# ============================================================
# APP
# ============================================================
APP_PORT=3001
APP_ENV="development"
FRONTEND_URL="http://localhost:3000"
